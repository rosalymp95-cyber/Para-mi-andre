<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Nuestro Universo 💖</title>

<style>
body {
  margin: 0;
  height: 100vh;
  overflow: hidden;
  font-family: 'Arial', sans-serif;
  color: white;
  text-align: center;
  background: radial-gradient(circle at bottom, #0a0a2a, #000);
}

/* estrellas */
.stars {
  position: absolute;
  width: 100%;
  height: 100%;
  background: url('https://i.imgur.com/9QZ7Z6F.png');
  animation: moveStars 60s linear infinite;
  opacity: 0.4;
}

@keyframes moveStars {
  from { transform: translate(0,0); }
  to { transform: translate(-500px, -500px); }
}

.container {
  position: relative;
  z-index: 2;
  top: 30%;
}

h1 {
  font-size: 2.5em;
  margin-bottom: 20px;
}

/* texto que aparece poco a poco */
.texto {
  font-size: 20px;
  opacity: 0;
  animation: aparecer 2s forwards;
}

.texto:nth-child(2) { animation-delay: 1s; }
.texto:nth-child(3) { animation-delay: 2s; }
.texto:nth-child(4) { animation-delay: 3s; }
.texto:nth-child(5) { animation-delay: 4s; }
.texto:nth-child(6) { animation-delay: 5s; }

@keyframes aparecer {
  to {
    opacity: 1;
    transform: translateY(-10px);
  }
}

/* frase final */
.final {
  margin-top: 40px;
  font-size: 22px;
  color: #ff4da6;
  opacity: 0;
  animation: aparecer 2s forwards;
  animation-delay: 6s;
}
</style>

</head>

<body>

<div class="stars"></div>

<div class="container">
  <h1>🌌 Nuestro universo 💖</h1>

  <div class="texto">Te amo 💖</div>
  <div class="texto">Mi rey 👑</div>
  <div class="texto">Mi niño 🥺</div>
  <div class="texto">Mi bebé 💕</div>
  <div class="texto">Eres el mejor ✨</div>
  <div class="texto">Gracias por estos 2 años y casi 2 meses 💫</div>

  <div class="final">Siempre tú… siempre nosotros 💖</div>
</div>

</body>
</html>
